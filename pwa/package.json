    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^12.8.2",
    "bitcoinjs-lib": "^6.1.7",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ecpair": "^3.0.0",
    "lucide-vue-next": "^0.477.0",
