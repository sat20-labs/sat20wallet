    "verify:wallet-basics": "node scripts/verify/wallet-basics-flow.mjs",
    "verify:l1-orderbook": "node scripts/verify/l1-orderbook-flow.mjs",
    "verify:l2-contract": "node scripts/verify/l2-contract-flow.mjs"
  },
